FROM python:3.12-slim
ENV DEBIAN_FRONTEND=noninteractive

# Add only the system tools required by the scientific workflow.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    curl && \
    rm -rf /var/lib/apt/lists/*

# Pin every scientific dependency to an exact version.
RUN pip install --no-cache-dir \
    numpy==1.26.4 \
    scipy==1.13.1 \
    pytest==8.4.1

WORKDIR /app

# bench's verifier hardening forces --rootdir=/app; pre-create it so pytest doesn't error.
# bench's skill-injection symlinks land in /home/agent/.claude/ etc.; pre-create with permissive
# ownership so the sandbox `agent` user can write session-env there.
RUN mkdir -p /app /home/agent/.claude /home/agent/.codex /home/agent/.opencode /home/agent/.agents && \
    chmod -R 777 /home/agent

# Bundled inputs. Frozen test fixtures, not live data.
COPY input.npz /root/input.npz

# DO NOT bake skills here. `bench eval run --skill-mode with-skill --skills-dir <skills-dir>` injects them at deploy time.
# If you copy them in, the without-skills experiment becomes a no-op.
