#!/bin/bash
set -u

mkdir -p /logs/verifier

# Copy the agent's scientific output for reviewer inspection.
# Adjust paths to match the task.
[ -f /root/result.json ] && cp /root/result.json /logs/verifier/result.json
[ -f /root/output.csv ] && cp /root/output.csv /logs/verifier/output.csv

# Run pytest. CRITICAL: capture exit code immediately after pytest, never after a pipe.
# `pytest ... | tee ...; if [ $? -eq 0 ]` reports tee's exit code (always 0), making every
# reward 1.0 — a silent failure mode that hides agent regressions.
python3 -m pytest \
  -p no:cacheprovider \
  /verifier/test_outputs.py -rA -v > /logs/verifier/output.txt 2>&1
RC=$?

cat /logs/verifier/output.txt

if [ $RC -eq 0 ]; then echo 1 > /logs/verifier/reward.txt; else echo 0 > /logs/verifier/reward.txt; fi
exit 0
